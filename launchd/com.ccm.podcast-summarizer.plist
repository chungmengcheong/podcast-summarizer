<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ccm.podcast-summarizer</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PODDIGEST_REPOSITORY__/scripts/run-scheduled-poddigest.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__PODDIGEST_REPOSITORY__</string>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>5</integer>
    <key>Hour</key>
    <integer>15</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__PODDIGEST_REPOSITORY__/logs/launchd/stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__PODDIGEST_REPOSITORY__/logs/launchd/stderr.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
